@using Microsoft.AspNetCore.Components.Web
@inject OpenGate.Web.Services.ThemeCssProvider ThemeCssProvider
@inject OpenGate.Web.Services.BrandingProvider BrandingProvider
@inject OpenGate.Application.Interfaces.ICaptchaService CaptchaService

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="css/site.css" rel="stylesheet" />
    @if (!string.IsNullOrEmpty(_themeCss))
    {
        <style>@((MarkupString)_themeCss)</style>
    }
    <link href="OpenGate.Web.styles.css" rel="stylesheet" />
    <HeadOutlet @rendermode="RenderMode.InteractiveServer" />
    <title>@_siteName</title>
</head>
<body>
    <Routes @rendermode="RenderMode.InteractiveServer" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @if (!string.IsNullOrEmpty(_captchaScriptUrl))
    {
        <script src="@_captchaScriptUrl" async defer></script>
    }
    <script src="js/captcha.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>

@code {
    private string _themeCss = "";
    private string _siteName = "OpenGate";
    private string _captchaScriptUrl = "";

    protected override async Task OnInitializedAsync()
    {
        _themeCss = await ThemeCssProvider.GetCssAsync();
        var branding = await BrandingProvider.GetAsync();
        _siteName = branding.SiteName;
        var captchaConfig = await CaptchaService.GetConfigAsync();
        _captchaScriptUrl = captchaConfig.IsConfigured ? captchaConfig.ScriptUrl : "";
    }
}
