@page "/admin/settings"
@attribute [Authorize(Roles = "Admin")]
@inject ISettingService SettingService
@inject BrandingProvider BrandingProvider
@inject CurrencyProvider CurrencyProvider
@inject IClamAvService ClamAvService
@inject ICaptchaService CaptchaService
@inject IWebHostEnvironment Environment
@inject FileUploadService FileUploadService
@inject IExtensionConfigRepository ExtensionConfigRepo

<div class="page-header">
    <h1>Settings</h1>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_error != null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
else
{
    @if (_successMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @_successMessage
            <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
        </div>
    }

    <div class="card">
        <div class="card-header p-0 border-bottom-0">
            <ul class="nav nav-tabs card-header-tabs" role="tablist">
                @foreach (var tab in _tabOrder)
                {
                    @if (_groupedSettings.ContainsKey(tab))
                    {
                        <li class="nav-item" role="presentation">
                            <button class="nav-link d-flex align-items-center gap-2 @(_activeTab == tab ? "active" : "")"
                                    type="button" role="tab"
                                    @onclick="() => _activeTab = tab">
                                <i class="bi @GetGroupIcon(tab)"></i>
                                @tab
                            </button>
                        </li>
                    }
                }
            </ul>
        </div>
        <div class="card-body">
            @if (_activeTab == "Payment")
            {
                <ul class="nav nav-pills mb-3">
                    @foreach (var entry in PaymentPrefixes)
                    {
                        @if (_paymentSettings.ContainsKey(entry.Key))
                        {
                            <li class="nav-item">
                                <button class="nav-link @(_activePaymentTab == entry.Key ? "active" : "")"
                                        type="button"
                                        @onclick="() => _activePaymentTab = entry.Key">
                                    <i class="bi @entry.Value.Icon me-1"></i> @entry.Value.Label
                                </button>
                            </li>
                        }
                    }
                </ul>

                @if (_paymentSettings.TryGetValue(_activePaymentTab, out var paySettings))
                {
                    <EditForm Model="_formModel" OnValidSubmit="() => SaveSettings(paySettings)">
                        @foreach (var setting in paySettings)
                        {
                            @RenderField(setting, _activePaymentTab)
                        }
                        <button type="submit" class="btn btn-primary" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            Save
                        </button>
                    </EditForm>
                }
            }
            else if (_activeTab == "Provisioning")
            {
                <ul class="nav nav-pills mb-3">
                    @foreach (var entry in ProvisionerPrefixes)
                    {
                        @if (_provisioningSettings.ContainsKey(entry.Key))
                        {
                            <li class="nav-item">
                                <button class="nav-link @(_activeProvisionerTab == entry.Key ? "active" : "")"
                                        type="button"
                                        @onclick="() => _activeProvisionerTab = entry.Key">
                                    <i class="bi @entry.Value.Icon me-1"></i> @entry.Value.Label
                                </button>
                            </li>
                        }
                    }
                </ul>

                @if (_provisioningSettings.TryGetValue(_activeProvisionerTab, out var provSettings))
                {
                    <EditForm Model="_formModel" OnValidSubmit="() => SaveSettings(provSettings)">
                        @foreach (var setting in provSettings)
                        {
                            @RenderField(setting, _activeProvisionerTab)
                        }
                        <button type="submit" class="btn btn-primary" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            Save
                        </button>
                    </EditForm>
                }
            }
            else if (_groupedSettings.TryGetValue(_activeTab, out var groupSettings))
            {
                <EditForm Model="_formModel" OnValidSubmit="() => SaveSettings(groupSettings)">
                    @foreach (var setting in groupSettings)
                    {
                        @RenderField(setting, null)
                    }
                    <button type="submit" class="btn btn-primary" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Save
                    </button>
                </EditForm>
            }
        </div>
    </div>
}

@code {
    private List<SettingDto> _settings = new();
    private Dictionary<string, string> _groupValues = new();
    private Dictionary<string, List<SettingDto>> _groupedSettings = new();
    private Dictionary<string, List<SettingDto>> _paymentSettings = new();
    private Dictionary<string, List<SettingDto>> _provisioningSettings = new();
    private readonly object _formModel = new();
    private string _activeTab = "General";
    private string _activePaymentTab = "Stripe";
    private string _activeProvisionerTab = "Pterodactyl";
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private string? _successMessage;

    private static readonly string[] _tabOrder = ["General", "Email", "Payment", "Provisioning"];

    private static readonly Dictionary<string, (string Label, string Icon)> PaymentPrefixes = new()
    {
        ["Stripe"] = ("Stripe", "bi-stripe"),
        ["PayPal"] = ("PayPal", "bi-paypal"),
        ["Heleket"] = ("Heleket", "bi-currency-bitcoin"),
        ["Cryptomus"] = ("Cryptomus", "bi-coin"),
        ["NowPayments"] = ("NOWPayments", "bi-wallet2"),
        ["BtcPayServer"] = ("BTCPay Server", "bi-currency-bitcoin")
    };

    private static readonly Dictionary<string, (string Label, string Icon)> ProvisionerPrefixes = new()
    {
        ["Pterodactyl"] = ("Pterodactyl", "bi-controller"),
        ["Proxmox"] = ("Proxmox VE", "bi-pc-display"),
        ["VirtFusion"] = ("VirtFusion", "bi-hdd-rack")
    };

    private RenderFragment RenderField(SettingDto setting, string? stripPrefix) => __builder =>
    {
        var key = setting.Key;
        var label = !string.IsNullOrEmpty(stripPrefix) && key.StartsWith(stripPrefix, StringComparison.OrdinalIgnoreCase)
            ? key[stripPrefix.Length..]
            : key;

        if (key == "LogoUrl")
        {
            <div class="mb-3">
                <label class="form-label fw-medium">Logo</label>
                <small class="text-muted d-block mb-2">Upload an image or paste a URL. Supports PNG, JPG, GIF, SVG, WebP (max 2 MB).</small>

                @{ var currentLogo = _groupValues.GetValueOrDefault(key, setting.Value); }
                @if (!string.IsNullOrWhiteSpace(currentLogo))
                {
                    <div class="d-flex align-items-center gap-3 mb-3 p-3 rounded" style="background: var(--bg-elevated, #f8f9fa); border: 1px solid var(--border, #dee2e6);">
                        <img src="@currentLogo" alt="Current logo" style="max-height: 48px; max-width: 200px; object-fit: contain;" />
                        <div class="flex-grow-1">
                            <code class="small text-break">@currentLogo</code>
                        </div>
                        <button type="button" class="btn btn-outline-danger btn-sm" @onclick="RemoveLogo" @onclick:preventDefault>
                            <i class="bi bi-trash me-1"></i>Remove
                        </button>
                    </div>
                }

                <div class="row g-2 align-items-end">
                    <div class="col">
                        <label class="form-label small text-muted mb-1">Upload file</label>
                        <InputFile OnChange="HandleLogoUpload" accept="image/*"
                                   class="form-control" id="logo-upload" />
                    </div>
                    <div class="col-auto d-flex align-items-center" style="padding-bottom: 2px;">
                        <span class="text-muted small fw-medium">or</span>
                    </div>
                    <div class="col">
                        <label class="form-label small text-muted mb-1">Image URL</label>
                        <input type="text" class="form-control" placeholder="https://example.com/logo.png"
                               value="@_groupValues.GetValueOrDefault(key, setting.Value)"
                               @onchange="@(e => _groupValues[key] = e.Value?.ToString() ?? "")" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_logoUploadError))
                {
                    <div class="text-danger small mt-2"><i class="bi bi-exclamation-circle me-1"></i>@_logoUploadError</div>
                }
                @if (_logoUploading)
                {
                    <div class="text-muted small mt-2"><span class="spinner-border spinner-border-sm me-1"></span>Uploading...</div>
                }
            </div>
            return;
        }

        <div class="mb-3">
            <label class="form-label fw-medium">@FormatLabel(label)</label>
            @if (!string.IsNullOrEmpty(setting.Description))
            {
                <small class="text-muted d-block mb-1">@setting.Description</small>
            }
            @if (IsPasswordField(key))
            {
                <input type="password" class="form-control" value="@_groupValues.GetValueOrDefault(key, setting.Value)"
                       @onchange="@(e => _groupValues[key] = e.Value?.ToString() ?? "")" />
            }
            else if (IsBooleanField(key))
            {
                <div class="form-check form-switch mt-1">
                    <input type="checkbox" class="form-check-input" checked="@(GetBoolValue(key, setting.Value))"
                           @onchange="@(e => _groupValues[key] = (e.Value is true ? "true" : "false"))" />
                    <label class="form-check-label text-muted">@(GetBoolValue(key, setting.Value) ? "Enabled" : "Disabled")</label>
                </div>
            }
            else if (IsDropdownField(key))
            {
                <select class="form-select" value="@_groupValues.GetValueOrDefault(key, setting.Value)"
                        @onchange="@(e => _groupValues[key] = e.Value?.ToString() ?? "")">
                    @foreach (var opt in GetDropdownOptions(key))
                    {
                        <option value="@opt.Value">@opt.Label</option>
                    }
                </select>
            }
            else
            {
                <input type="text" class="form-control" value="@_groupValues.GetValueOrDefault(key, setting.Value)"
                       @onchange="@(e => _groupValues[key] = e.Value?.ToString() ?? "")" />
            }
        </div>
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _settings = (await SettingService.GetAllAsync()).ToList();
            foreach (var s in _settings)
                _groupValues[s.Key] = s.Value;

            _groupedSettings = _settings
                .GroupBy(s => string.IsNullOrEmpty(s.Group) ? "General" : s.Group)
                .ToDictionary(g => g.Key, g => g.ToList());

            BuildSubGroupMap(_groupedSettings.GetValueOrDefault("Payment") ?? [], PaymentPrefixes, _paymentSettings);
            BuildSubGroupMap(_groupedSettings.GetValueOrDefault("Provisioning") ?? [], ProvisionerPrefixes, _provisioningSettings);

            if (!_paymentSettings.ContainsKey(_activePaymentTab) && _paymentSettings.Any())
                _activePaymentTab = _paymentSettings.Keys.First();

            if (!_provisioningSettings.ContainsKey(_activeProvisionerTab) && _provisioningSettings.Any())
                _activeProvisionerTab = _provisioningSettings.Keys.First();

            _activeTab = _groupedSettings.Keys
                .OrderBy(g => Array.IndexOf(_tabOrder, g) is var i && i >= 0 ? i : 99)
                .FirstOrDefault() ?? "General";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static void BuildSubGroupMap(List<SettingDto> settings,
        Dictionary<string, (string Label, string Icon)> prefixes,
        Dictionary<string, List<SettingDto>> target)
    {
        foreach (var prefix in prefixes.Keys)
        {
            var matching = settings.Where(s => s.Key.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)).ToList();
            if (matching.Any())
                target[prefix] = matching;
        }
    }

    private async Task SaveSettings(List<SettingDto> settings)
    {
        _saving = true;
        _error = null;
        _successMessage = null;
        try
        {
            foreach (var setting in settings)
            {
                if (_groupValues.TryGetValue(setting.Key, out var value))
                    await SettingService.SetValueAsync(setting.Key, value);
            }
            BrandingProvider.InvalidateCache();
            CurrencyProvider.InvalidateCache();
            CaptchaService.InvalidateCache();
            ((ClamAvService)ClamAvService).InvalidateCache();

            await SyncExtensionConfigAsync(settings);

            _successMessage = "Settings saved.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SyncExtensionConfigAsync(List<SettingDto> settings)
    {
        string? activePrefix = _activeTab switch
        {
            "Payment" => _activePaymentTab,
            "Provisioning" => _activeProvisionerTab,
            _ => null
        };
        if (activePrefix == null) return;

        var extInfo = GetExtensionInfo(activePrefix);
        if (extInfo == null) return;

        var (name, displayName, type) = extInfo.Value;
        var enabledKey = $"{activePrefix}Enabled";
        var isEnabled = _groupValues.TryGetValue(enabledKey, out var enabledVal)
            && string.Equals(enabledVal, "true", StringComparison.OrdinalIgnoreCase);

        var extSettings = new Dictionary<string, string>();
        foreach (var setting in settings)
        {
            if (setting.Key.StartsWith(activePrefix, StringComparison.OrdinalIgnoreCase)
                && !setting.Key.Equals(enabledKey, StringComparison.OrdinalIgnoreCase))
            {
                extSettings[setting.Key[activePrefix.Length..]] = _groupValues.GetValueOrDefault(setting.Key, setting.Value);
            }
        }

        var existing = await ExtensionConfigRepo.GetByNameAsync(name);
        if (existing == null)
        {
            await ExtensionConfigRepo.CreateAsync(new ExtensionConfig
            {
                Name = name,
                DisplayName = displayName,
                Type = type,
                IsEnabled = isEnabled,
                Settings = extSettings
            });
        }
        else
        {
            existing.IsEnabled = isEnabled;
            existing.Settings = extSettings;
            await ExtensionConfigRepo.UpdateAsync(existing);
        }
    }

    private static (string Name, string DisplayName, ExtensionType Type)? GetExtensionInfo(string prefix)
    {
        if (PaymentPrefixes.TryGetValue(prefix, out var payInfo))
            return (prefix.ToLowerInvariant(), payInfo.Label, ExtensionType.PaymentGateway);
        if (ProvisionerPrefixes.TryGetValue(prefix, out var provInfo))
            return (prefix.ToLowerInvariant(), provInfo.Label, ExtensionType.ServerProvisioner);
        return null;
    }

    private static string FormatLabel(string key)
    {
        var result = System.Text.RegularExpressions.Regex.Replace(key, "([a-z])([A-Z])", "$1 $2");
        result = System.Text.RegularExpressions.Regex.Replace(result, "([A-Z]+)([A-Z][a-z])", "$1 $2");
        return result;
    }

    private static string GetGroupIcon(string group) => group switch
    {
        "General" => "bi-sliders",
        "Email" => "bi-envelope",
        "Payment" => "bi-credit-card",
        "Provisioning" => "bi-server",
        _ => "bi-gear"
    };

    private static bool IsPasswordField(string key) =>
        key.Contains("Secret", StringComparison.OrdinalIgnoreCase) ||
        key.Contains("Password", StringComparison.OrdinalIgnoreCase) ||
        key.Contains("ApiToken", StringComparison.OrdinalIgnoreCase) ||
        (key.Contains("Key", StringComparison.OrdinalIgnoreCase) && key.Contains("Api", StringComparison.OrdinalIgnoreCase));

    private static bool IsBooleanField(string key) =>
        key.Contains("Enabled", StringComparison.OrdinalIgnoreCase) ||
        key.Contains("Sandbox", StringComparison.OrdinalIgnoreCase) ||
        key.Contains("UseSsl", StringComparison.OrdinalIgnoreCase) ||
        key.Equals("TaxInclusive", StringComparison.OrdinalIgnoreCase);

    private static bool IsDropdownField(string key) =>
        key.Equals("CaptchaProvider", StringComparison.OrdinalIgnoreCase) ||
        key.Equals("Currency", StringComparison.OrdinalIgnoreCase) ||
        key.Equals("EmailProvider", StringComparison.OrdinalIgnoreCase);

    private static (string Value, string Label)[] GetDropdownOptions(string key) => key switch
    {
        "CaptchaProvider" =>
        [
            ("None", "None"),
            ("RecaptchaV2", "reCAPTCHA v2"),
            ("RecaptchaV3", "reCAPTCHA v3"),
            ("HCaptcha", "hCaptcha"),
            ("Turnstile", "Cloudflare Turnstile")
        ],
        "Currency" =>
        [
            ("USD", "USD ($) — US Dollar"),
            ("EUR", "EUR (€) — Euro"),
            ("GBP", "GBP (£) — British Pound"),
            ("CAD", "CAD (C$) — Canadian Dollar"),
            ("AUD", "AUD (A$) — Australian Dollar"),
            ("JPY", "JPY (¥) — Japanese Yen"),
            ("CHF", "CHF (Fr) — Swiss Franc"),
            ("CNY", "CNY (¥) — Chinese Yuan"),
            ("INR", "INR (₹) — Indian Rupee"),
            ("BRL", "BRL (R$) — Brazilian Real"),
            ("MXN", "MXN (Mex$) — Mexican Peso"),
            ("KRW", "KRW (₩) — South Korean Won"),
            ("SEK", "SEK (kr) — Swedish Krona"),
            ("NOK", "NOK (kr) — Norwegian Krone"),
            ("DKK", "DKK (kr) — Danish Krone"),
            ("PLN", "PLN (zł) — Polish Złoty"),
            ("TRY", "TRY (₺) — Turkish Lira"),
            ("ZAR", "ZAR (R) — South African Rand"),
            ("SGD", "SGD (S$) — Singapore Dollar"),
            ("HKD", "HKD (HK$) — Hong Kong Dollar"),
            ("NZD", "NZD (NZ$) — New Zealand Dollar"),
            ("CZK", "CZK (Kč) — Czech Koruna"),
            ("ILS", "ILS (₪) — Israeli Shekel"),
            ("THB", "THB (฿) — Thai Baht"),
            ("AED", "AED (د.إ) — UAE Dirham"),
            ("SAR", "SAR (﷼) — Saudi Riyal"),
            ("RUB", "RUB (₽) — Russian Ruble"),
            ("PHP", "PHP (₱) — Philippine Peso"),
            ("TWD", "TWD (NT$) — Taiwan Dollar"),
            ("IDR", "IDR (Rp) — Indonesian Rupiah"),
            ("MYR", "MYR (RM) — Malaysian Ringgit"),
            ("CLP", "CLP (CL$) — Chilean Peso"),
            ("ARS", "ARS (AR$) — Argentine Peso"),
            ("COP", "COP (COL$) — Colombian Peso"),
            ("EGP", "EGP (E£) — Egyptian Pound"),
            ("NGN", "NGN (₦) — Nigerian Naira"),
            ("BGN", "BGN (лв) — Bulgarian Lev"),
            ("HUF", "HUF (Ft) — Hungarian Forint"),
            ("RON", "RON (lei) — Romanian Leu"),
            ("HRK", "HRK (kn) — Croatian Kuna"),
            ("UAH", "UAH (₴) — Ukrainian Hryvnia")
        ],
        "EmailProvider" =>
        [
            ("SMTP", "SMTP"),
            ("SendGrid", "SendGrid")
        ],
        _ => []
    };

    private bool GetBoolValue(string key, string fallback)
    {
        var val = _groupValues.GetValueOrDefault(key, fallback);
        return string.Equals(val, "true", StringComparison.OrdinalIgnoreCase);
    }

    private bool _logoUploading;
    private string? _logoUploadError;
    private static readonly HashSet<string> AllowedLogoTypes = ["image/png", "image/jpeg", "image/gif", "image/svg+xml", "image/webp", "image/x-icon"];

    private async Task HandleLogoUpload(InputFileChangeEventArgs e)
    {
        _logoUploadError = null;
        _logoUploading = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            using var ms = new MemoryStream();
            await using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            var result = await FileUploadService.UploadLogoAsync(ms, file.Name, file.Size);
            if (!result.Success)
            {
                _logoUploadError = result.Error;
                return;
            }

            _groupValues["LogoUrl"] = result.Url!;
            await SettingService.SetValueAsync("LogoUrl", result.Url!);
            BrandingProvider.InvalidateCache();
            _successMessage = "Logo uploaded successfully.";
        }
        catch (Exception ex)
        {
            _logoUploadError = $"Upload failed: {ex.Message}";
        }
        finally
        {
            _logoUploading = false;
            StateHasChanged();
        }
    }

    private async Task RemoveLogo()
    {
        _logoUploadError = null;
        try
        {
            var uploadsDir = Path.Combine(Environment.WebRootPath, "uploads");
            if (Directory.Exists(uploadsDir))
            {
                foreach (var old in Directory.EnumerateFiles(uploadsDir, "logo.*"))
                {
                    try { File.Delete(old); } catch { }
                }
            }

            _groupValues["LogoUrl"] = "";
            await SettingService.SetValueAsync("LogoUrl", "");
            BrandingProvider.InvalidateCache();
            _successMessage = "Logo removed.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _logoUploadError = $"Remove failed: {ex.Message}";
        }
    }
}
