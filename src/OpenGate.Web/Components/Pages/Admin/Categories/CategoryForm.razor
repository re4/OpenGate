@page "/admin/categories/create"
@page "/admin/categories/edit/{Id}"
@attribute [Authorize(Roles = "Admin")]
@inject ICategoryService CategoryService
@inject NavigationManager Navigation

<div class="page-header">
    <h1>@(IsEdit ? "Edit category" : "New category")</h1>
</div>

@if (_loading && IsEdit)
{
    <div class="text-center py-5">
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_error != null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
else
{
    <EditForm Model="_model" OnValidSubmit="HandleSave">
        <DataAnnotationsValidator />
        <div class="card">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <InputText @bind-Value="_model.Name" class="form-control" placeholder="Category name" />
                        <ValidationMessage For="@(() => _model.Name)" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Slug</label>
                        <InputText @bind-Value="_model.Slug" class="form-control" placeholder="url-slug" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <InputTextArea @bind-Value="_model.Description" class="form-control" rows="2" placeholder="Optional description" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Sort Order</label>
                        <InputNumber @bind-Value="_model.SortOrder" class="form-control" />
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check">
                            <InputCheckbox @bind-Value="_model.IsActive" class="form-check-input" id="isActive" />
                            <label class="form-check-label" for="isActive">Active</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Save
                </button>
                <a href="/admin/categories" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public string? Id { get; set; }

    private CreateCategoryDto _model = new();
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private bool IsEdit => !string.IsNullOrEmpty(Id);

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            try
            {
                var cat = await CategoryService.GetByIdAsync(Id!);
                if (cat == null)
                {
                    _error = "Category not found.";
                }
                else
                {
                    _model = new CreateCategoryDto
                    {
                        Name = cat.Name,
                        Description = cat.Description,
                        Slug = cat.Slug,
                        SortOrder = cat.SortOrder,
                        IsActive = cat.IsActive
                    };
                }
            }
            catch (Exception ex)
            {
                _error = ex.Message;
            }
        }
        _loading = false;
    }

    private async Task HandleSave()
    {
        _saving = true;
        _error = null;
        try
        {
            if (IsEdit)
            {
                await CategoryService.UpdateAsync(Id!, new UpdateCategoryDto
                {
                    Name = _model.Name,
                    Description = _model.Description,
                    Slug = _model.Slug,
                    SortOrder = _model.SortOrder,
                    IsActive = _model.IsActive
                });
            }
            else
            {
                await CategoryService.CreateAsync(_model);
            }
            Navigation.NavigateTo("/admin/categories");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
