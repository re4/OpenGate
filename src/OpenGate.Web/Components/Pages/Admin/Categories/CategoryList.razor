@page "/admin/categories"
@attribute [Authorize(Roles = "Admin")]
@inject ICategoryService CategoryService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1>Categories</h1>
    <a href="/admin/categories/create" class="btn btn-primary">Add category</a>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_error != null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
else if (!_categories.Any())
{
    <div class="card">
        <div class="card-body">
            <div class="empty-state">
                <i class="bi bi-folder d-block"></i>
                <p class="mb-3">No categories yet</p>
                <a href="/admin/categories/create" class="btn btn-primary">Add Category</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th>Sort Order</th>
                        <th>Active</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in _categories.OrderBy(c => c.SortOrder))
                    {
                        <tr>
                            <td>@cat.Name</td>
                            <td><code>@(cat.Slug ?? "-")</code></td>
                            <td>@cat.SortOrder</td>
                            <td>
                                @if (cat.IsActive)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>
                                <a href="/admin/categories/edit/@cat.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(cat)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<CategoryDto> _categories = new();
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _categories = (await CategoryService.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ConfirmDelete(CategoryDto cat)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete \"{cat.Name}\"?");
        if (confirmed)
        {
            try
            {
                await CategoryService.DeleteAsync(cat.Id);
                _categories.Remove(cat);
            }
            catch (Exception ex)
            {
                _error = ex.Message;
            }
        }
    }
}
