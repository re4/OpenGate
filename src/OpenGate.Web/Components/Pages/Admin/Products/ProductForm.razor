@page "/admin/products/create"
@page "/admin/products/edit/{Id}"
@attribute [Authorize(Roles = "Admin")]
@inject IProductService ProductService
@inject ICategoryService CategoryService
@inject NavigationManager Navigation

<div class="page-header">
    <h1>@(IsEdit ? "Edit product" : "New product")</h1>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_error != null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
else
{
    <EditForm Model="_model" OnValidSubmit="HandleSave">
        <DataAnnotationsValidator />
        <div class="card">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label">Name</label>
                        <InputText @bind-Value="_model.Name" class="form-control" placeholder="Product name" />
                        <ValidationMessage For="@(() => _model.Name)" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Category</label>
                        <InputSelect @bind-Value="_model.CategoryId" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var cat in _categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => _model.CategoryId)" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <InputTextArea @bind-Value="_model.Description" class="form-control" rows="3" placeholder="Product description" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Price</label>
                        <InputNumber @bind-Value="_model.Price" class="form-control" />
                        <ValidationMessage For="@(() => _model.Price)" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Setup Fee</label>
                        <InputNumber @bind-Value="_model.SetupFee" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Billing Cycle</label>
                        <InputSelect @bind-Value="_model.BillingCycle" class="form-select">
                            @foreach (BillingCycle cycle in Enum.GetValues(typeof(BillingCycle)))
                            {
                                <option value="@cycle">@cycle</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Stock (-1 = unlimited)</label>
                        <InputNumber @bind-Value="_model.Stock" class="form-control" />
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check">
                            <InputCheckbox @bind-Value="_model.IsActive" class="form-check-input" id="isActive" />
                            <label class="form-check-label" for="isActive">Active</label>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />
                <h5 class="mb-3">Configurable Options</h5>
                @for (var i = 0; i < _model.ConfigurableOptions.Count; i++)
                {
                    var idx = i;
                    var opt = _model.ConfigurableOptions[idx];
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <strong>Option @(idx + 1)</strong>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveOption(idx)">
                                    <i class="bi bi-trash"></i> Remove
                                </button>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <input type="text" class="form-control form-control-sm" placeholder="Option name" @bind="opt.Name" />
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control form-control-sm" placeholder="Environment variable" @bind="opt.EnvironmentVariable" />
                                </div>
                            </div>
                            <div class="small text-muted mb-2">Values (Label, Value, PriceModifier - one per line)</div>
                            @for (var v = 0; v < opt.Values.Count; v++)
                            {
                                var vi = v;
                                <div class="input-group input-group-sm mb-1">
                                    <input type="text" class="form-control" placeholder="Label" @bind="opt.Values[vi].Label" />
                                    <input type="text" class="form-control" placeholder="Value" @bind="opt.Values[vi].Value" />
                                    <input type="number" step="0.01" class="form-control" placeholder="Price mod" @bind="opt.Values[vi].PriceModifier" />
                                    <button type="button" class="btn btn-outline-secondary" @onclick="() => RemoveOptionValue(idx, vi)">
                                        <i class="bi bi-dash"></i>
                                    </button>
                                </div>
                            }
                            <button type="button" class="btn btn-sm btn-outline-secondary mt-1" @onclick="() => AddOptionValue(idx)">
                                <i class="bi bi-plus"></i> Add Value
                            </button>
                        </div>
                    </div>
                }
                <button type="button" class="btn btn-outline-primary" @onclick="AddOption">
                    <i class="bi bi-plus-lg me-1"></i>Add Option
                </button>
            </div>
            <div class="card-footer d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Save
                </button>
                <a href="/admin/products" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public string? Id { get; set; }

    private CreateProductDto _model = new();
    private List<CategoryDto> _categories = new();
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private bool IsEdit => !string.IsNullOrEmpty(Id);

    protected override async Task OnInitializedAsync()
    {
        _categories = (await CategoryService.GetAllAsync()).ToList();

        if (IsEdit)
        {
            try
            {
                var product = await ProductService.GetByIdAsync(Id!);
                if (product == null)
                {
                    _error = "Product not found.";
                    _loading = false;
                    return;
                }
                _model = new CreateProductDto
                {
                    Name = product.Name,
                    Description = product.Description,
                    CategoryId = product.CategoryId,
                    Price = product.Price,
                    SetupFee = product.SetupFee,
                    BillingCycle = product.BillingCycle,
                    Stock = product.Stock,
                    IsActive = product.IsActive,
                    ServerId = product.ServerId,
                    Metadata = product.Metadata ?? new Dictionary<string, string>(),
                    ConfigurableOptions = product.ConfigurableOptions?.Select(o => new ConfigurableOptionDto
                    {
                        Name = o.Name,
                        EnvironmentVariable = o.EnvironmentVariable,
                        Values = o.Values?.Select(v => new ConfigurableOptionValueDto { Label = v.Label, Value = v.Value, PriceModifier = v.PriceModifier }).ToList() ?? new()
                    }).ToList() ?? new()
                };
            }
            catch (Exception ex)
            {
                _error = ex.Message;
            }
        }
        _loading = false;
    }

    private void AddOption()
    {
        _model.ConfigurableOptions.Add(new ConfigurableOptionDto { Values = new List<ConfigurableOptionValueDto> { new() } });
    }

    private void RemoveOption(int idx)
    {
        _model.ConfigurableOptions.RemoveAt(idx);
    }

    private void AddOptionValue(int optIdx)
    {
        _model.ConfigurableOptions[optIdx].Values.Add(new ConfigurableOptionValueDto());
    }

    private void RemoveOptionValue(int optIdx, int valIdx)
    {
        _model.ConfigurableOptions[optIdx].Values.RemoveAt(valIdx);
    }

    private async Task HandleSave()
    {
        _saving = true;
        _error = null;
        try
        {
            if (IsEdit)
            {
                await ProductService.UpdateAsync(Id!, new UpdateProductDto
                {
                    Name = _model.Name,
                    Description = _model.Description,
                    CategoryId = _model.CategoryId,
                    Price = _model.Price,
                    SetupFee = _model.SetupFee,
                    BillingCycle = _model.BillingCycle,
                    Stock = _model.Stock,
                    IsActive = _model.IsActive,
                    ServerId = _model.ServerId,
                    Metadata = _model.Metadata,
                    ConfigurableOptions = _model.ConfigurableOptions
                });
            }
            else
            {
                await ProductService.CreateAsync(_model);
            }
            Navigation.NavigateTo("/admin/products");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
