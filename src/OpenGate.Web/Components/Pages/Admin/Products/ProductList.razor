@page "/admin/products"
@attribute [Authorize(Roles = "Admin")]
@inject IProductService ProductService
@inject ICategoryService CategoryService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1>Products</h1>
    <a href="/admin/products/create" class="btn btn-primary">Add product</a>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_error != null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
else if (!_products.Any())
{
    <div class="card">
        <div class="card-body">
            <div class="empty-state">
                <i class="bi bi-box-seam d-block"></i>
                <p class="mb-3">No products yet</p>
                <a href="/admin/products/create" class="btn btn-primary">Add Product</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Billing Cycle</th>
                        <th>Stock</th>
                        <th>Active</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in _products)
                    {
                        var category = _categories.FirstOrDefault(c => c.Id == product.CategoryId);
                        <tr>
                            <td>@product.Name</td>
                            <td>@(category?.Name ?? "-")</td>
                            <td class="font-mono">@product.Price.ToString("C2")</td>
                            <td>@product.BillingCycle</td>
                            <td>@(product.Stock == -1 ? "Unlimited" : product.Stock.ToString())</td>
                            <td>
                                @if (product.IsActive)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>
                                <a href="/admin/products/edit/@product.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(product)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<ProductDto> _products = new();
    private List<CategoryDto> _categories = new();
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var productsTask = ProductService.GetAllAsync();
            var categoriesTask = CategoryService.GetAllAsync();
            await Task.WhenAll(productsTask, categoriesTask);
            _products = (await productsTask).ToList();
            _categories = (await categoriesTask).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ConfirmDelete(ProductDto product)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete \"{product.Name}\"?");
        if (confirmed)
        {
            try
            {
                await ProductService.DeleteAsync(product.Id);
                _products.Remove(product);
            }
            catch (Exception ex)
            {
                _error = ex.Message;
            }
        }
    }
}
