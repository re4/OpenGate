@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@inject IDashboardService DashboardService

<div class="page-header">
    <h1>Dashboard</h1>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_error != null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <span class="stat-icon"><i class="bi bi-currency-dollar"></i></span>
                    <div class="stat-label">Total Revenue</div>
                    <div class="stat-value font-mono">@_stats.TotalRevenue.ToString("C2")</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <span class="stat-icon"><i class="bi bi-cart-check"></i></span>
                    <div class="stat-label">Total Orders</div>
                    <div class="stat-value">@_stats.TotalOrders</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <span class="stat-icon"><i class="bi bi-lightning-charge"></i></span>
                    <div class="stat-label">Active Orders</div>
                    <div class="stat-value">@_stats.ActiveOrders</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <span class="stat-icon"><i class="bi bi-chat-dots"></i></span>
                    <div class="stat-label">Open Tickets</div>
                    <div class="stat-value">@_stats.OpenTickets</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Recent orders</h5>
                </div>
                <div class="card-body p-0">
                    @if (_stats.RecentOrders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Total</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in _stats.RecentOrders.Take(5))
                                    {
                                        <tr>
                                            <td><span class="font-mono">@(order.Id.Length > 12 ? order.Id[..12] + "..." : order.Id)</span></td>
                                            <td class="font-mono">@order.Total.ToString("C2")</td>
                                            <td><span class="badge badge-status status-@order.Status.ToString().ToLowerInvariant()">@order.Status</span></td>
                                            <td>@order.CreatedAt.ToString("MMM d, yyyy")</td>
                                            <td>
                                                <a href="/admin/orders/@order.Id" class="btn btn-sm btn-outline-primary">View</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-inbox d-block"></i>
                            <p class="mb-0">No recent orders</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Monthly revenue</h5>
                </div>
                <div class="card-body">
                    @if (_stats.MonthlyRevenue.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var month in _stats.MonthlyRevenue)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <span>@month.Month</span>
                                    <span class="fw-semibold font-mono">@month.Amount.ToString("C2")</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="empty-state py-4">
                            <i class="bi bi-bar-chart d-block"></i>
                            <p class="mb-0">No revenue data</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DashboardStatsDto _stats = new();
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _stats = await DashboardService.GetStatsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
