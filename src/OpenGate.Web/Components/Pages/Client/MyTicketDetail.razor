@page "/my/tickets/{Id}"
@attribute [Authorize]
@inject ITicketService TicketService
@inject AuthenticationStateProvider AuthStateProvider
@inject FileUploadService FileUploadService

<PageTitle>Ticket @(_ticket?.Subject ?? "") - OpenGate</PageTitle>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else if (_ticket == null || !_isOwner)
{
    <div class="empty-state">
        <i class="bi bi-shield-x d-block"></i>
        <h5>Ticket not found</h5>
        <p class="mb-3">This ticket does not exist or you don't have access to it.</p>
        <a href="/my/tickets" class="btn btn-primary">Back to My Tickets</a>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/my/tickets">Support</a></li>
            <li class="breadcrumb-item active">@_ticket.Subject</li>
        </ol>
    </nav>

    <div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1>@_ticket.Subject</h1>
            <div class="d-flex gap-2 flex-wrap">
                <span class="badge badge-status status-@_ticket.Status.ToString().ToLowerInvariant()">@_ticket.Status</span>
                <span class="badge badge-status priority-@_ticket.Priority.ToString().ToLowerInvariant()">@_ticket.Priority</span>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <h6 class="text-muted mb-2">Messages</h6>
        @foreach (var msg in _ticket.Messages.OrderBy(m => m.CreatedAt))
        {
            <div class="ticket-message @(msg.IsStaff ? "staff" : "")">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <strong>@msg.SenderName</strong>
                    <small class="text-muted">@msg.CreatedAt.ToString("MMM d, yyyy HH:mm")</small>
                </div>
                <div class="text-break">@msg.Body</div>
                @if (msg.Attachments.Any())
                {
                    <div class="mt-2">
                        @foreach (var att in msg.Attachments)
                        {
                            <a href="@att.Url" target="_blank" class="d-inline-flex align-items-center gap-1 me-3 small text-decoration-none">
                                <i class="bi bi-paperclip"></i> @att.FileName
                                <span class="text-muted">(@FormatSize(att.Size))</span>
                            </a>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @if (_ticket.Status != TicketStatus.Closed)
    {
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Reply</h5>
            </div>
            <div class="card-body">
                <EditForm Model="_replyModel" OnValidSubmit="SendReply">
                    <div class="mb-3">
                        <label for="reply" class="form-label">Your message</label>
                        <InputTextArea id="reply" @bind-Value="_replyModel.Body" class="form-control" rows="4"
                                       placeholder="Type your reply..." />
                        <ValidationMessage For="@(() => _replyModel.Body)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Attachments <span class="text-muted small">(optional)</span></label>
                        <InputFile OnChange="HandleFileSelected" multiple accept="image/*,video/*,.txt,.log"
                                   class="form-control" />
                        <small class="text-muted">Max @_maxSizeDisplay per file. Allowed: images, videos, .txt, .log</small>
                    </div>
                    @if (_selectedFiles.Any())
                    {
                        <div class="mb-3">
                            @foreach (var (file, idx) in _selectedFiles.Select((f, i) => (f, i)))
                            {
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <i class="bi bi-paperclip"></i>
                                    <span class="small">@file.Name <span class="text-muted">(@FormatSize(file.Size))</span></span>
                                    <button type="button" class="btn btn-link btn-sm text-danger p-0" @onclick="() => RemoveFile(idx)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                        @if (_isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        Send Reply
                    </button>
                </EditForm>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-secondary">
            This ticket is closed. Open a new ticket if you need further assistance.
        </div>
    }
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private TicketDto? _ticket;
    private ReplyModel _replyModel = new();
    private bool _loading = true;
    private string? _errorMessage;
    private bool _isOwner;
    private bool _isSubmitting;
    private List<IBrowserFile> _selectedFiles = new();
    private long _maxUploadBytes = 1L * 1024 * 1024 * 1024;
    private string _maxSizeDisplay = "1 GB";

    protected override async Task OnInitializedAsync()
    {
        _maxUploadBytes = await FileUploadService.GetMaxUploadSizeForClientAsync();
        _maxSizeDisplay = FormatSizeShort(_maxUploadBytes);
        await LoadTicketAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Id))
        {
            await LoadTicketAsync();
        }
    }

    private async Task LoadTicketAsync()
    {
        _loading = true;
        _errorMessage = null;
        _isOwner = false;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(userId))
            {
                _loading = false;
                return;
            }

            _ticket = await TicketService.GetByIdAsync(Id);
            if (_ticket != null)
            {
                _isOwner = _ticket.UserId == userId;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFiles = e.GetMultipleFiles(5).ToList();
    }

    private void RemoveFile(int index)
    {
        if (index >= 0 && index < _selectedFiles.Count)
            _selectedFiles.RemoveAt(index);
    }

    private async Task SendReply()
    {
        if (_ticket == null || string.IsNullOrEmpty(_replyModel.Body)) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        var userName = authState.User.Identity?.Name ?? "User";

        if (string.IsNullOrEmpty(userId))
        {
            _errorMessage = "You must be logged in to reply.";
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var attachments = new List<TicketAttachmentDto>();
            foreach (var file in _selectedFiles)
            {
                using var ms = new MemoryStream();
                await using var stream = file.OpenReadStream(maxAllowedSize: _maxUploadBytes);
                await stream.CopyToAsync(ms);
                ms.Position = 0;

                var result = await FileUploadService.UploadTicketAttachmentAsync(ms, file.Name, file.Size, Id);
                if (result.Success && result.Url != null)
                {
                    attachments.Add(new TicketAttachmentDto
                    {
                        FileName = file.Name,
                        Url = result.Url,
                        Size = file.Size
                    });
                }
                else if (!result.Success)
                {
                    _errorMessage = result.Error;
                    _isSubmitting = false;
                    return;
                }
            }

            await TicketService.AddMessageAsync(Id, new CreateTicketMessageDto
            {
                SenderId = userId,
                SenderName = userName,
                IsStaff = false,
                Body = _replyModel.Body,
                Attachments = attachments
            });
            _replyModel.Body = "";
            _selectedFiles.Clear();
            await LoadTicketAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes is >= 0 and <= 1023) return $"{bytes} B";
        if (bytes is >= 1024 and <= 1048575) return $"{bytes / 1024.0:F1} KB";
        if (bytes is >= 1048576 and <= 1073741823) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F1} GB";
    }

    private static string FormatSizeShort(long bytes)
    {
        if (bytes is >= 0 and <= 1048575) return $"{bytes / 1024} KB";
        if (bytes is >= 1048576 and <= 1073741823) return $"{bytes / (1024 * 1024)} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):G3} GB";
    }

    private class ReplyModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Message is required")]
        public string? Body { get; set; }
    }
}
