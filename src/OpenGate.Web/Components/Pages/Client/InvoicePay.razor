@page "/my/invoices/{Id}/pay"
@attribute [Authorize]
@inject IInvoiceService InvoiceService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject CurrencyProvider CurrencyProvider
@inject IExtensionConfigRepository ExtensionConfigRepo
@inject IEnumerable<IPaymentGateway> PaymentGateways
@inject ISettingService SettingService

<PageTitle>Pay Invoice - OpenGate</PageTitle>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_invoice == null || !_isOwner)
{
    <div class="empty-state">
        <i class="bi bi-shield-x d-block"></i>
        <h5>Invoice not found</h5>
        <a href="/my/invoices" class="btn btn-primary mt-3">Back to Invoices</a>
    </div>
}
else if (_invoice.Status == InvoiceStatus.Paid)
{
    <div class="alert alert-success">This invoice has already been paid.</div>
    <a href="/my/invoices" class="btn btn-primary">Back to Invoices</a>
}
else
{
    <div class="page-header">
        <h1>Pay invoice</h1>
    </div>

    <div class="card">
        <div class="card-body">
            <p class="mb-2">Amount due: <strong class="font-mono">@_currency.Format(_invoice.Total)</strong></p>
            <p class="text-muted small mb-4">Due date: @_invoice.DueDate.ToString("MMM d, yyyy")</p>

            @if (_paymentError != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @_paymentError
                    <button type="button" class="btn-close" @onclick="() => _paymentError = null"></button>
                </div>
            }

            @if (!_enabledGateways.Any())
            {
                <div class="alert alert-info">
                    No payment gateways are currently enabled. Please contact support to complete payment.
                </div>
            }
            else
            {
                <h6 class="mb-3">Select a payment method</h6>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    @foreach (var gw in _enabledGateways)
                    {
                        <button class="btn btn-outline-primary d-flex align-items-center gap-2 px-4 py-3"
                                disabled="@_processingPayment"
                                @onclick="() => ProcessPaymentAsync(gw)">
                            @if (_processingGateway == gw.Name)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                            }
                            else
                            {
                                <i class="bi @GetGatewayIcon(gw.Name)"></i>
                            }
                            @gw.DisplayName
                        </button>
                    }
                </div>
            }

            <a href="/my/invoices" class="btn btn-outline-secondary">Back to Invoices</a>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private InvoiceDto? _invoice;
    private CurrencyInfo _currency = new();
    private bool _loading = true;
    private bool _isOwner;
    private List<ExtensionConfig> _enabledGateways = new();
    private bool _processingPayment;
    private string? _processingGateway;
    private string? _paymentError;

    private static string GetGatewayIcon(string name) => name switch
    {
        "stripe" => "bi-stripe",
        "paypal" => "bi-paypal",
        "heleket" => "bi-currency-bitcoin",
        "cryptomus" => "bi-coin",
        "nowpayments" => "bi-wallet2",
        "btcpayserver" => "bi-currency-bitcoin",
        _ => "bi-credit-card"
    };

    protected override async Task OnInitializedAsync()
    {
        _currency = await CurrencyProvider.GetAsync();
        await LoadInvoiceAsync();

        var configs = await ExtensionConfigRepo.GetByTypeAsync(ExtensionType.PaymentGateway);
        _enabledGateways = configs.Where(c => c.IsEnabled).ToList();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Id))
        {
            await LoadInvoiceAsync();
        }
    }

    private async Task LoadInvoiceAsync()
    {
        _loading = true;
        _isOwner = false;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(userId))
            {
                _loading = false;
                return;
            }

            _invoice = await InvoiceService.GetByIdAsync(Id);
            if (_invoice != null)
            {
                _isOwner = _invoice.UserId == userId;
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ProcessPaymentAsync(ExtensionConfig config)
    {
        _processingPayment = true;
        _processingGateway = config.Name;
        _paymentError = null;
        StateHasChanged();

        try
        {
            var gateway = PaymentGateways.FirstOrDefault(g => g.Name == config.Name);
            if (gateway == null)
            {
                _paymentError = $"Payment gateway '{config.DisplayName}' is not available.";
                return;
            }

            await gateway.InitializeAsync(config.Settings);

            var siteUrlSetting = await SettingService.GetByKeyAsync("SiteUrl");
            var siteUrl = siteUrlSetting?.Value ?? Navigation.BaseUri.TrimEnd('/');

            var request = new PaymentRequest
            {
                InvoiceId = _invoice!.Id,
                Amount = _invoice.Total,
                Currency = _invoice.Currency,
                Description = $"Invoice {_invoice.InvoiceNumber}",
                ReturnUrl = $"{siteUrl}/my/invoices/{_invoice.Id}",
                CancelUrl = $"{siteUrl}/my/invoices/{_invoice.Id}/pay",
                Metadata = new Dictionary<string, string>
                {
                    ["InvoiceId"] = _invoice.Id,
                    ["InvoiceNumber"] = _invoice.InvoiceNumber
                }
            };

            var result = await gateway.CreatePaymentAsync(request);
            if (result.Success && !string.IsNullOrEmpty(result.PaymentUrl))
            {
                Navigation.NavigateTo(result.PaymentUrl, forceLoad: true);
            }
            else
            {
                _paymentError = result.ErrorMessage ?? "Failed to initiate payment. Please try again.";
            }
        }
        catch (Exception)
        {
            _paymentError = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _processingPayment = false;
            _processingGateway = null;
            StateHasChanged();
        }
    }
}
