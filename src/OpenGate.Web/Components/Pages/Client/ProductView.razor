@page "/store/product/{Id}"
@attribute [AllowAnonymous]
@inject IProductService ProductService
@inject CartService CartService
@inject NavigationManager Navigation
@inject CurrencyProvider CurrencyProvider

<PageTitle>@(_product?.Name ?? "Product") - OpenGate</PageTitle>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else if (_product == null)
{
    <div class="empty-state">
        <i class="bi bi-box-seam d-block"></i>
        <h5>Product not found</h5>
        <a href="/store" class="btn btn-primary mt-3">Back to Store</a>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/store">Store</a></li>
            <li class="breadcrumb-item active">@_product.Name</li>
        </ol>
    </nav>

    <div class="page-header">
        <h1>@_product.Name</h1>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(_product.Description))
                    {
                        <p class="text-muted mb-0">@_product.Description</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Pricing</h5>
                    <div class="mb-2">
                        <span class="font-mono product-price fs-3">@_currency.Format(_calculatedPrice)</span>
                        <span class="product-cycle">/ @FormatBillingCycle(_product.BillingCycle)</span>
                    </div>
                    @if (_product.SetupFee.HasValue && _product.SetupFee > 0)
                    {
                        <p class="text-muted small mb-2">
                            Setup fee: <span class="font-mono">@_currency.Format(_product.SetupFee.Value)</span>
                        </p>
                    }

                    @if (_product.ConfigurableOptions.Any())
                    {
                        <hr />
                        <h6 class="mb-3">Options</h6>
                        @foreach (var opt in _product.ConfigurableOptions)
                        {
                            <div class="mb-3">
                                <label class="form-label">@opt.Name</label>
                                <select class="form-select" value="@_selectedOptions.GetValueOrDefault(opt.Name)"
                                        @onchange="e => UpdateOption(opt.Name, e.Value?.ToString())">
                                    <option value="">-- Select --</option>
                                    @foreach (var val in opt.Values)
                                    {
                                        <option value="@val.Value">
                                            @val.Label
                                            @(val.PriceModifier != 0 ? $" ({val.PriceModifier:+#0.00;-0.00;0})" : "")
                                        </option>
                                    }
                                </select>
                            </div>
                        }
                    }

                    <hr />
                    <button type="button" class="btn btn-primary w-100" @onclick="AddToCart">
                        <i class="bi bi-cart-plus me-1"></i>Add to Cart
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private ProductDto? _product;
    private decimal _calculatedPrice;
    private CurrencyInfo _currency = new();
    private Dictionary<string, string> _selectedOptions = new();
    private bool _loading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        _currency = await CurrencyProvider.GetAsync();
        await LoadProductAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Id))
        {
            await LoadProductAsync();
        }
    }

    private async Task LoadProductAsync()
    {
        _loading = true;
        _errorMessage = null;
        try
        {
            _product = await ProductService.GetByIdAsync(Id);
            if (_product != null)
            {
                _calculatedPrice = _product.Price;
                _selectedOptions = _product.ConfigurableOptions.ToDictionary(o => o.Name, _ => "");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void UpdateOption(string name, string? value)
    {
        _selectedOptions[name] = value ?? "";
        RecalculatePrice();
    }

    private void RecalculatePrice()
    {
        if (_product == null) return;
        _calculatedPrice = _product.Price;
        foreach (var opt in _product.ConfigurableOptions)
        {
            if (_selectedOptions.TryGetValue(opt.Name, out var val) && !string.IsNullOrEmpty(val))
            {
                var selectedVal = opt.Values.FirstOrDefault(v => v.Value == val);
                if (selectedVal != null)
                    _calculatedPrice += selectedVal.PriceModifier;
            }
        }
    }

    private void AddToCart()
    {
        if (_product == null) return;

        var options = _selectedOptions
            .Where(kvp => !string.IsNullOrEmpty(kvp.Value))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);

        CartService.AddItem(new CartItemDto
        {
            ProductId = _product.Id,
            ProductName = _product.Name,
            UnitPrice = _calculatedPrice,
            Quantity = 1,
            BillingCycle = _product.BillingCycle,
            SelectedOptions = options
        });

        Navigation.NavigateTo("/cart");
    }

    private static string FormatBillingCycle(BillingCycle cycle) => cycle switch
    {
        BillingCycle.OneTime => "one-time",
        BillingCycle.Monthly => "mo",
        BillingCycle.Quarterly => "quarter",
        BillingCycle.SemiAnnually => "6 mo",
        BillingCycle.Annually => "year",
        _ => cycle.ToString().ToLowerInvariant()
    };
}
