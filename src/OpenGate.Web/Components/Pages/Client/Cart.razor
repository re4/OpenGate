@page "/cart"
@attribute [Authorize]
@inject CartService CartService
@inject NavigationManager Navigation

<PageTitle>Cart - OpenGate</PageTitle>

<div class="page-header">
    <h1>Cart</h1>
</div>

@if (CartService.Items.Count == 0)
{
    <div class="empty-state">
        <i class="bi bi-cart-x d-block"></i>
        <h5>Your cart is empty</h5>
        <p class="mb-3">Add some products from our store to get started.</p>
        <a href="/store" class="btn btn-primary">Continue shopping</a>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Options</th>
                            <th>Billing Cycle</th>
                            <th>Unit Price</th>
                            <th>Quantity</th>
                            <th>Line Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (item, index) in CartService.Items.Select((item, i) => (item, i)))
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>
                                    @if (item.SelectedOptions != null && item.SelectedOptions.Any())
                                    {
                                        <small class="text-muted">
                                            @string.Join(", ", item.SelectedOptions.Select(kvp => $"{kvp.Key}: {kvp.Value}"))
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>@FormatBillingCycle(item.BillingCycle)</td>
                                <td><span class="font-mono">@item.UnitPrice.ToString("C")</span></td>
                                <td>
                                    <input type="number" class="form-control form-control-sm" style="width: 70px;"
                                           min="1" value="@item.Quantity"
                                           @onchange="e => UpdateQty(index, e)" />
                                </td>
                                <td><span class="font-mono">@((item.UnitPrice * item.Quantity).ToString("C"))</span></td>
                                <td>
                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                            @onclick='() => RemoveItem(index)'>
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
            <div class="fw-bold fs-5">Total: <span class="font-mono">@CartService.Total.ToString("C")</span></div>
            <div class="d-flex gap-2">
                <a href="/store" class="btn btn-outline-secondary">Continue shopping</a>
                <a href="/checkout" class="btn btn-primary">Checkout</a>
            </div>
        </div>
    </div>
}

@code {
    private void UpdateQty(int index, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var qty) && qty > 0)
        {
            CartService.UpdateQuantity(index, qty);
        }
    }

    private void RemoveItem(int index)
    {
        CartService.RemoveItem(index);
    }

    private static string FormatBillingCycle(BillingCycle cycle) => cycle switch
    {
        BillingCycle.OneTime => "One-time",
        BillingCycle.Monthly => "Monthly",
        BillingCycle.Quarterly => "Quarterly",
        BillingCycle.SemiAnnually => "Semi-annually",
        BillingCycle.Annually => "Annually",
        _ => cycle.ToString()
    };
}
