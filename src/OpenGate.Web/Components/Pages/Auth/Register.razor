@page "/register"
@attribute [AllowAnonymous]
@inject NavigationManager Navigation
@inject ICaptchaService CaptchaService
@inject IJSRuntime JS

<PageTitle>Register - OpenGate</PageTitle>

<div class="card auth-card auth-card-wide">
    <div class="card-body">
        <h2 class="mb-2">Create account</h2>
        <p class="text-muted mb-4" style="font-size: 0.8125rem;">Fill in your details to get started.</p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        <form method="post" action="/account/register" id="registerForm">
            <AntiforgeryToken />

            <div class="row">
                <div class="col-6 mb-3">
                    <label for="firstName" class="form-label">First Name</label>
                    <input id="firstName" name="firstName" type="text" class="form-control" required />
                </div>
                <div class="col-6 mb-3">
                    <label for="lastName" class="form-label">Last Name</label>
                    <input id="lastName" name="lastName" type="text" class="form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input id="email" name="email" type="email" class="form-control" placeholder="you@example.com" required />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input id="password" name="password" type="password" class="form-control" minlength="8" required />
            </div>

            <div class="mb-3">
                <label for="confirmPassword" class="form-label">Confirm Password</label>
                <input id="confirmPassword" name="confirmPassword" type="password" class="form-control" minlength="8" required />
            </div>

            @if (_captchaConfig is { IsConfigured: true, RegisterEnabled: true })
            {
                @if (_captchaConfig.Provider == "RecaptchaV3")
                {
                    <input type="hidden" name="captcha-token" id="register-captcha-token" />
                }
                else
                {
                    <div class="mb-3">
                        <div id="register-captcha-container"></div>
                        <input type="hidden" name="captcha-token" id="register-captcha-token" />
                    </div>
                }
            }

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg" @onclick="HandleSubmit">Create Account</button>
            </div>
        </form>

        <hr class="my-4" />
        <p class="text-center text-muted mb-0" style="font-size: 0.8125rem;">
            Already have an account? <a href="/login">Sign in</a>
        </p>
    </div>
</div>

@code {
    private string? _errorMessage;
    private CaptchaConfig? _captchaConfig;

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _errorMessage = Error;
        _captchaConfig = await CaptchaService.GetConfigAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _captchaConfig is { IsConfigured: true, RegisterEnabled: true })
        {
            if (_captchaConfig.Provider == "RecaptchaV3")
            {
                await Task.Delay(500);
                try
                {
                    var token = await JS.InvokeAsync<string>("captchaInterop.executeV3", _captchaConfig.SiteKey);
                    await JS.InvokeVoidAsync("eval", $"document.getElementById('register-captcha-token').value = '{token}'");
                }
                catch { }
            }
            else
            {
                await Task.Delay(500);
                try
                {
                    var dotNetRef = DotNetObjectReference.Create(this);
                    await JS.InvokeVoidAsync("captchaInterop.render", "register-captcha-container", _captchaConfig.Provider, _captchaConfig.SiteKey, dotNetRef);
                }
                catch { }
            }
        }
    }

    [JSInvokable]
    public async Task OnCaptchaCallback(string token)
    {
        await JS.InvokeVoidAsync("eval", $"document.getElementById('register-captcha-token').value = '{token}'");
    }

    private async Task HandleSubmit()
    {
        if (_captchaConfig is { IsConfigured: true, RegisterEnabled: true, Provider: "RecaptchaV3" })
        {
            try
            {
                var token = await JS.InvokeAsync<string>("captchaInterop.executeV3", _captchaConfig.SiteKey);
                await JS.InvokeVoidAsync("eval", $"document.getElementById('register-captcha-token').value = '{token}'");
            }
            catch { }
        }
    }
}
