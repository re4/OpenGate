@page "/login"
@attribute [AllowAnonymous]
@inject NavigationManager Navigation
@inject ICaptchaService CaptchaService
@inject IJSRuntime JS

<PageTitle>Sign in - OpenGate</PageTitle>

<div class="card auth-card">
    <div class="card-body">
        <h2>Sign in</h2>
        <p class="text-muted mb-4" style="font-size: 0.8125rem;">Enter your credentials to continue.</p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        <form method="post" action="/account/login" id="loginForm">
            <AntiforgeryToken />

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input id="email" name="email" type="email" class="form-control" placeholder="you@example.com" required />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input id="password" name="password" type="password" class="form-control" required />
            </div>

            @if (_captchaConfig is { IsConfigured: true, LoginEnabled: true })
            {
                @if (_captchaConfig.Provider == "RecaptchaV3")
                {
                    <input type="hidden" name="captcha-token" id="captcha-token" />
                }
                else
                {
                    <div class="mb-3">
                        <div id="login-captcha-container"></div>
                        <input type="hidden" name="captcha-token" id="captcha-token" />
                    </div>
                }
            }

            <button type="submit" class="btn btn-primary w-100" @onclick="HandleSubmit">Sign in</button>
        </form>

        <hr />
        <p class="text-center text-muted mb-0" style="font-size: 0.8125rem;">
            No account? <a href="/register">Create one</a>
        </p>
    </div>
</div>

@code {
    private string? _errorMessage;
    private CaptchaConfig? _captchaConfig;

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _errorMessage = Error;
        _captchaConfig = await CaptchaService.GetConfigAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _captchaConfig is { IsConfigured: true, LoginEnabled: true })
        {
            if (_captchaConfig.Provider == "RecaptchaV3")
            {
                await Task.Delay(500);
                try
                {
                    var token = await JS.InvokeAsync<string>("captchaInterop.executeV3", _captchaConfig.SiteKey);
                    await JS.InvokeVoidAsync("eval", $"document.getElementById('captcha-token').value = '{token}'");
                }
                catch { }
            }
            else
            {
                await Task.Delay(500);
                try
                {
                    var dotNetRef = DotNetObjectReference.Create(this);
                    await JS.InvokeVoidAsync("captchaInterop.render", "login-captcha-container", _captchaConfig.Provider, _captchaConfig.SiteKey, dotNetRef);
                }
                catch { }
            }
        }
    }

    [JSInvokable]
    public async Task OnCaptchaCallback(string token)
    {
        await JS.InvokeVoidAsync("eval", $"document.getElementById('captcha-token').value = '{token}'");
    }

    private async Task HandleSubmit()
    {
        if (_captchaConfig is { IsConfigured: true, LoginEnabled: true, Provider: "RecaptchaV3" })
        {
            try
            {
                var token = await JS.InvokeAsync<string>("captchaInterop.executeV3", _captchaConfig.SiteKey);
                await JS.InvokeVoidAsync("eval", $"document.getElementById('captcha-token').value = '{token}'");
            }
            catch { }
        }
    }
}
